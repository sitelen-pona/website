<h3 id="tier{{index}}words">
{%- assign en = "Tier " | append: index | append: " Word Characters" -%}
        {%- assign sp = "sitelen nimi pi(suli nanpa" | append: indexsp | append: ")"-%}
        {%- assign sL = "sitelen nimi pi suli #" | append: indexsl  -%}

        {% include "partials/ui-translate.liquid", 
            enName: en,
            spName: sp, 
            sLName: sL %}
</h3>
<div class="word-grid">
    {%- for entry in words  -%}
                <span class="cell">
                <span class="word-glyph">
                {%- if entry.placeholder -%}
                {{ entry.placeholder }}
                {%- else -%}
                &#x{{ entry.codepoint }};
                {%- endif -%}
                </span>
                <div class="word-name">
                    {{ entry.name }}<br>
                </div>
                <div class="tech">{{ entry.technical_name }}</div>
                </span>
    {%- endfor -%}
</div>
