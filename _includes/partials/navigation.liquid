 <nav>
        {%- for item in navigation  -%}
            {%- if item.category -%}
                <span class="nav-category">{% include "partials/ui-translate.liquid", item: item %}</span>
                <ul>
                {%- for child in item.children  -%}
                <li><a href="{{child.link}}">{% include "partials/ui-translate.liquid", item: child %}</a></li>
                {%- endfor -%}
                </ul>
            {%- else -%}
            <a href="{{item.link}}">{% include "partials/ui-translate.liquid", item: item %}</a>
            {%- endif -%}
    {%- endfor -%}
</nav>