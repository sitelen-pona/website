  "punctuation": [
   {
    "name": "between words or tokens (zero-width)",
    "input": "",
    "explain": "Fontmakers rely on this invisible glyph to separate units from each other",
    "example-before": "mi 'zero-width-space' pona",
    "example-after": "mi pona",
    "no-codepoint": "true"
   },
   {
    "name": [
      "start of cartouche",
      "end of cartouche"
    ],
    "input": [
      "[",
      "]"
    ], 
    "explain": "Paired with each other, these glyphs can be used to write a container for proper names",
        "example-before": "jan 'cartouche start' anpa mama awen 'cartouche end'",
    "example-after": "jan [anpa mama awen]",
    "pair": "true"

   },
   {
    "name": "combined glyph, decided by font <br>(zero-width joiner)",
    "input": "luka&luka",
    "explain": "This invisible glyph is used to combine two glyphs in a way the fontmaker specifies. Depending on the shape of the glyphs and preferences of the fontmaker, the combination may end up stacked, nested, or combined some other way.",
    "example-before": "soweli 'zw-joiner' suwi li kalama 'zw-joiner' jaki",
    "example-after": "soweli&suwi li kalama&jaki",
    "no-codepoint": "true"
   },
   {
    "name": "combined glyph, written above <br>(stacking joiner)",
    "input": "luka-luka",
    "explain": "This invisible glyph is used to combine two glyphs by stacking the second glyph over the first.",
    "example-before": "soweli 'stack-joiner' suwi li kalama 'stack-joiner' jaki",
    "example-after": "soweli-suwi li kalama-jaki"
   },
   {
    "name": "combined glyph, written inside <br>(scaling joiner)",
    "input": "luka+luka",
    "explain": "This invisible glyph is used to combine two glyphs by writing the second glyph inside the first.",
    "example-before": "soweli 'scale-joiner' suwi li kalama 'scale-joiner' jaki",
    "example-after": "soweli+suwi li kalama+jaki"

   },
   {
    "name": "ideographic space",
    "input": "|",
    "explain": "This glyph is used to create a visible space, which can be used as sentence-ending punctuation, or within the indented style.",
    "example-before": "mi toki 'ideographic space' sina toki ala",
    "example-after": "mi toki zz sina toki ala",
    "no-codepoint": "true"

   }
  ]
